{
  "manifest_version": 3,
  "name": "Video Recorder",
  "version": "1.0",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.netflix.com/*",
    "https://www.primevideo.com/*",
    "https://www.disneyplus.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.disneyplus.com/*",
        "https://www.primevideo.com/*",
        "https://www.netflix.com/*"
      ],
      "js": [
        "contentScript.js"
      ]
    }
  ]
}